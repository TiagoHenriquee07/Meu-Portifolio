                        </a>
                        <a href="https://github.com/TiagoHenriquee07" target="_blank" title="github">
                            <i class="fab fa-github"></i>
                        </a>
                        <a href="mailto:th05112007@gmail.com" title="email">
                            <i class="fas fa-envelope"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
